# monitor agent config — copy to /etc/monitor-agent/config.env and fill in values.

# ── LLM for anomaly classification ────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=qwen2.5:7b

# ── Proxmox ───────────────────────────────────────────────────────────────────
PROXMOX_URL=https://192.168.0.69:8006
# Format: user@realm!tokenid=secret  (from .proxmox-creds)
PROXMOX_TOKEN=<user@pve!tokenid>=<secret>

# ── Kubernetes ────────────────────────────────────────────────────────────────
# Path to kubeconfig with read access.
KUBECONFIG=/home/erniepy/.kube/config

# ── Health check endpoints ─────────────────────────────────────────────────────
HEALTH_ENDPOINTS=https://api.starstalk.io/health,https://api-dev.starstalk.io/health

# ── Remote knowledge base ──────────────────────────────────────────────────────
CONFIG_WORKER_TOKEN=<machine-jwt>

# ── GitHub (for opening issues on high-severity anomalies) ────────────────────
GITHUB_TOKEN=<github-pat>
GITHUB_REPO=<org>/starstalk

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL=60
LOG_FILE=/var/log/monitor-agent.log
