# bug-watcher config — copy to /etc/bug-watcher/config.env and fill in values.
# This file is NOT committed with secrets. The template has no real values.

# ── LLM backend (one of the following) ────────────────────────────────────────
# Local Ollama (recommended on GPU machine):
OLLAMA_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=qwen2.5-coder:14b-instruct-q4_K_M

# Or Anthropic API (cloud, paid):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Fine-grained PAT: Contents R+W + Pull requests R+W + Workflows R on the repo.
GITHUB_TOKEN=<github-pat>
# Format: owner/repo
GITHUB_REPO=<org>/starstalk

# ── Local repo ─────────────────────────────────────────────────────────────────
REPO_LOCAL_PATH=/home/erniepy/gh_repos/starstalk
CLAUDE_MD_PATH=/home/erniepy/gh_repos/starstalk/CLAUDE.md

# ── Remote knowledge base ──────────────────────────────────────────────────────
# Machine JWT from config.starstalk.io bootstrap.
CONFIG_WORKER_TOKEN=<machine-jwt>

# ── Daemon behaviour ───────────────────────────────────────────────────────────
POLL_INTERVAL=30
STATE_FILE=/var/lib/bug-watcher/state.json
MEMORY_FILE=/var/lib/bug-watcher/memory.json
